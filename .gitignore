# ==============================================
# Obsidian 核心本地配置（永不同步，避免冲突）
# ==============================================
# 工作区布局（手机/桌面端）
.obsidian/workspace*.json
# 缓存目录
.obsidian/cache/
# 插件本地配置（含插件数据、快捷键等）
.obsidian/plugins/
# 自定义CSS片段
.obsidian/snippets/
# 图谱配置
.obsidian/graph.json
# 移动版工作区
.obsidian/workspace-mobile.json
# Obsidian 临时文件
*.base
.trash/

# ==============================================
# 系统/IDE 垃圾文件（彻底屏蔽）
# ==============================================
# macOS 系统缓存
.DS_Store
# Windows 系统缓存
Thumbs.db
Desktop.ini
# VS Code 工作区缓存
.vs/
# Windows 快捷方式
*.lnk
# Obsidian Git 冲突记录
conflict-files-obsidian-git.md